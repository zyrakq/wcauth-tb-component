{
  "name": "wcauth-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun i18n:build && vite build",
    "postbuild": "bun build src/generated/locales/*.ts --outdir dist/locales --target browser --format esm --entry-naming \"[name].js\" && mkdir -p dist/xliff && cp xliff/*.xlf dist/xliff/",
    "dev": "vite build --watch",
    "i18n:extract": "lit-localize extract",
    "i18n:build": "lit-localize build"
  },
  "dependencies": {
    "@lit/localize": "^0.12.2",
    "lit": "^3.3.3"
  },
  "devDependencies": {
    "@lit/localize-tools": "^0.8.1",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}